+/// Owns the single AsyncIterator of a gRPC request stream. grpc-swift's
+/// GRPCAsyncRequestStream traps if more than one iterator is ever created,
+/// so every read for one RPC must go through the same instance.
+private final class SingleIteratorRequestStream<S: AsyncSequence> {
+  private var iterator: S.AsyncIterator
+
+  init(_ sequence: S) {
+    self.iterator = sequence.makeAsyncIterator()
+  }
+
+  func next() async throws -> S.Element? {
+    try await iterator.next()
+  }
+
+  var requiredNext: S.Element {
+    get async throws {
+      guard let next = try await next() else {
+        throw StreamReadError<S.Element>.nextElementNotProduced
+      }
+      return next
+    }
+  }
+}
