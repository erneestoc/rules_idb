# Bazel test sharding: the runner partitions the bundle's tests per shard.
ios_unit_test(
    name = "HostedTestsSharded",
    size = "medium",
    minimum_os_version = MINIMUM_OS_VERSION,
    runner = ":idb_runner",
    shard_count = 3,
    tags = ["manual"],
    test_host = ":HostApp",
    deps = [":HostedTestsLib"],
)

# The stock xcodebuild runner with a hand-rolled pooled simulator_creator
# (PID lockfiles + stale-lock stealing) — what teams write today to make
# --local_test_jobs work. Used by the benchmark as the apples-to-apples
# concurrency comparison against rules_idb's built-in pool.
sh_binary(
    name = "flock_simulator_creator",
    srcs = ["hooks/flock_simulator_creator.sh"],
)

sh_binary(
    name = "flock_simulator_cleanup",
    srcs = ["hooks/flock_simulator_cleanup.sh"],
)

ios_xctestrun_runner(
    name = "xcodebuild_pooled_runner",
    clean_up_simulator_action = ":flock_simulator_cleanup",
    create_simulator_action = ":flock_simulator_creator",
    device_type = "iPhone 17 Pro",
)

[
    ios_unit_test(
        name = "HostedTestsShard%d_xcb_pooled" % i,
        size = "medium",
        minimum_os_version = MINIMUM_OS_VERSION,
        runner = ":xcodebuild_pooled_runner",
        tags = ["manual"],
        test_host = ":HostApp",
        deps = [":HostedTestsLib"],
    )
    for i in range(1, 9)
]

# A test host inflated with a 400 MB opaque resource, used by the benchmark
# harness to measure staging/install wall time at a realistic app size.
# Random bytes defeat compression, so archive staging pays full price.
# Tagged manual: benchmark-only, too heavy for CI.
genrule(
    name = "big_asset",
    outs = ["big_asset.bin"],
    cmd = "dd if=/dev/urandom of=$@ bs=1m count=400 2>/dev/null",
    tags = ["manual"],
)

swift_library(
    name = "BigHostAppLib",
    srcs = ["HostApp/AppDelegate.swift"],
    data = [":big_asset"],
    module_name = "BigHostApp",
    tags = ["manual"],
)

ios_application(
    name = "BigHostApp",
    bundle_id = "com.rulesidb.example.BigHostApp",
    families = ["iphone"],
    infoplists = ["HostApp/BigInfo.plist"],
    minimum_os_version = MINIMUM_OS_VERSION,
    tags = ["manual"],
    deps = [":BigHostAppLib"],
)

ios_unit_test(
    name = "HostedTestsBig",
    size = "large",
    minimum_os_version = MINIMUM_OS_VERSION,
    runner = ":idb_runner",
    tags = ["manual"],
    test_host = ":BigHostApp",
    deps = [":HostedTestsLib"],
)

ios_unit_test(
    name = "HostedTestsBig_xcodebuild",
    size = "large",
    minimum_os_version = MINIMUM_OS_VERSION,
    runner = "@rules_apple//apple/testing/default_runner:ios_xctestrun_ordered_runner",
    tags = ["manual"],
    test_host = ":BigHostApp",
    deps = [":HostedTestsLib"],
)

