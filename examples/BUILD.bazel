# post_action_determines_exit_code: the post action fails (exit 7) even
# though the tests pass, so the target must FAIL. Tagged manual; used by the
# runner's own validation.
sh_binary(
    name = "failing_post_action",
    srcs = ["hooks/failing_post_action.sh"],
)

ios_idb_test_runner(
    name = "idb_post_gate_runner",
    device_type = "iPhone 17 Pro",
    post_action = ":failing_post_action",
    post_action_determines_exit_code = True,
)

