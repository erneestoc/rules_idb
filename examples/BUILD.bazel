load("@rules_apple//apple:ios.bzl", "ios_application", "ios_ui_test", "ios_unit_test")
load("@rules_apple//apple/testing/default_runner:ios_xctestrun_runner.bzl", "ios_xctestrun_runner")
load("@rules_shell//shell:sh_binary.bzl", "sh_binary")
load("@rules_swift//swift:swift.bzl", "swift_library")
load("@rules_idb//idb:idb_test_runner.bzl", "ios_idb_test_runner")

MINIMUM_OS_VERSION = "16.0"

swift_library(
    name = "HostAppLib",
    srcs = ["HostApp/AppDelegate.swift"],
    module_name = "HostApp",
)

ios_application(
    name = "HostApp",
    bundle_id = "com.rulesidb.example.HostApp",
    families = ["iphone"],
    infoplists = ["HostApp/Info.plist"],
    minimum_os_version = MINIMUM_OS_VERSION,
    deps = [":HostAppLib"],
)

swift_library(
    name = "HostedTestsLib",
    testonly = True,
    srcs = ["Tests/HostedTests.swift"],
    module_name = "HostedTests",
)

ios_idb_test_runner(
    name = "idb_runner",
    device_type = "iPhone 17 Pro",
)

# Runs with the idb-based runner from this repository.
ios_unit_test(
    name = "HostedTests",
    size = "medium",
    minimum_os_version = MINIMUM_OS_VERSION,
    runner = ":idb_runner",
    test_host = ":HostApp",
    deps = [":HostedTestsLib"],
)

# The same tests with the stock rules_apple xcodebuild-based runner, for
