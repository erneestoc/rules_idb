# Sharded copies used to demonstrate/benchmark concurrent simulator usage via
# --local_test_jobs=N. Each target is an independent test action, so Bazel can
# run them in parallel; the idb runner hands each one its own pooled simulator.
[
    ios_unit_test(
        name = "HostedTestsShard%d" % i,
        size = "medium",
        minimum_os_version = MINIMUM_OS_VERSION,
        runner = ":idb_runner",
        test_host = ":HostApp",
        deps = [":HostedTestsLib"],
    )
    for i in range(1, 9)
]

[
    ios_unit_test(
        name = "HostedTestsShard%d_xcodebuild" % i,
        size = "medium",
        minimum_os_version = MINIMUM_OS_VERSION,
        runner = "@rules_apple//apple/testing/default_runner:ios_xctestrun_ordered_runner",
        test_host = ":HostApp",
        deps = [":HostedTestsLib"],
    )
    for i in range(1, 9)
]

